# Usamos la imagen oficial de Java 17 (versión ligera "slim")
FROM openjdk:17-jdk-slim

# Creamos una carpeta dentro del contenedor donde vivirá nuestra app
WORKDIR /app

# Copiamos el archivo JAR compilado al contenedor
# El * es para no tener que escribir el nombre exacto con la versión
COPY target/*.jar eureka.jar

# Le decimos a Docker que el contenedor usa el puerto 8761
EXPOSE 8761

# Comando que se ejecuta cuando el contenedor arranca
ENTRYPOINT ["java", "-jar", "eureka.jar"]